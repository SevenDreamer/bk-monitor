{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
    
        {
            "name": "debug:run server",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}/bkmonitor",
            "args": [
                "runserver",
                "bkm-dev.paas3-dev.bktencent.com:8000"
            ],
            "django": true,
            "autoStartBrowser": false,
            "program": "manage.py",
            "autoReload": {
                "enable": true,
            },
            "justMyCode": false,
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "debug: run celery",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}/bkmonitor",
            "args": [
                // "export BKAPP_DEPLOY_PLATFORM=enterprise",
                // "export BK_PAAS_HOST=https://paas3-dev.bktencent.com/",
                // "export BKPAAS_APP_SECRET=446f11f1-50d8-4458-93d5-4a5ee9c36c75",
                "worker", 
                "-A", "config",
                "-l", "INFO",
                "-Q", "celery_resource",
                "-P", "solo"
            ],
            "module": "celery",
            "autoReload": {
                "enable": true
            },
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "shell",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}/bkmonitor",
            "program": "manage.py",
            "args": ["shell"],
            "console": "integratedTerminal",
            "autoReload": {
                "enable": true,
            },
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "pytest: file",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}/bkmonitor",
            "program": "pytest",
            "args": ["${file}"],
            "console": "integratedTerminal",
            // "autoReload": {
            //     "enable": true,
            // },
            // "justMyCode": false,
            "env": {
                "DJANGO_SETTINGS_MODULE":"settings",
                "DJANGO_CONF_MODULE":"conf.web.development.enterprise",
                "USE_DYNAMIC_SETTINGS":"0",
                "django_find_project": "false"
            },
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}
